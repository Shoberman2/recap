{
  "name": "recap-cli",
  "version": "0.1.0",
  "description": "Recap everything you've built on your laptop. Scans your git repos and shows what you shipped — today, this week, this month, this year, and all time.",
  "type": "module",
  "bin": {
    "recap": "./dist/cli.js"
  },
  "files": [
    "dist",
    "CLAUDE.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Shoberman2/recap.git"
  },
  "keywords": [
    "git",
    "recap",
    "developer",
    "cli",
    "productivity",
    "claude",
    "ai"
  ],
  "author": "Shoberman2",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Shoberman2/recap/issues"
  },
  "homepage": "https://github.com/Shoberman2/recap#readme",
  "dependencies": {
    "commander": "^14.0.3",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
